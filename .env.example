# Copiá este archivo como .env.local para desarrollo local
# En Vercel estas variables las ponés en: Settings → Environment Variables

# ── NOWPayments ──
# Lo encontrás en: nowpayments.io → API Keys
NOWPAYMENTS_API_KEY=tu_api_key_aqui

# ── NOWPayments IPN Secret ──
# Lo encontrás en: nowpayments.io → Store Settings → IPN Secret
# Sirve para verificar que los webhooks son legítimos
NOWPAYMENTS_IPN_SECRET=tu_ipn_secret_aqui

# ── URL de tu tienda en Vercel ──
# Ejemplo: https://sowystore.vercel.app
# Sin barra final
SITE_URL=https://tu-tienda.vercel.app
